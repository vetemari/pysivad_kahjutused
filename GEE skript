);

var MaskStudyArea = function(image) {
  return image.updateMask(studyRaster);
};

// ============================================================
// Satelliidiandmed ja pilved
// ============================================================

var S2 = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
  .filter(ee.Filter.date('2017-06-15', '2024-07-15'))
  .map(MaskStudyArea);

function bitwiseExtract(value, fromBit, toBit) {
  if (toBit === undefined) toBit = fromBit;
  var maskSize = ee.Number(1).add(toBit).subtract(fromBit);
  var mask = ee.Number(1).leftShift(maskSize).subtract(1);
  return value.rightShift(fromBit).bitwiseAnd(mask);
}

var maskClouds = function(image) {
  var quality = image.select('QA60');
  var cloudState = bitwiseExtract(quality, 10);
  var cirrusState = bitwiseExtract(quality, 11);
  var mask = cloudState.eq(0).and(cirrusState.eq(0));
  return image.updateMask(mask);
};

var filtereds2 = S2.map(maskClouds);

// ============================================================
// EVI arvutamine
// ============================================================

var years = ee.List.sequence(2017, 2024);
var months = ee.List.sequence(6, 7);

var yearMonthEVI = years.map(function(year) {
  return months.map(function(month) {
    var startDate = ee.Date.fromYMD(year, month, 1);
    var endDate = startDate.advance(1, 'month');

    var medianImage = filtereds2.filterDate(startDate, endDate)
      .select(['B8', 'B4', 'B2'])
      .median();

    var evi = medianImage.expression(
      '2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))', {
        'NIR': medianImage.select('B8').divide(10000),
        'RED': medianImage.select('B4').divide(10000),
        'BLUE': medianImage.select('B2').divide(10000)
      }).rename('EVI');

    return evi
      .set('system:time_start', startDate)
      .set('year', year)
      .set('month', month);
  });
}).flatten();

var eviCollection = ee.ImageCollection(yearMonthEVI);

// ============================================================
// Visualiseerimine
// ============================================================

var calculateMonthlyCompositeEVI = function(year, month) {
  var startDate = ee.Date.fromYMD(year, month, 1);
  var endDate = startDate.advance(1, 'month');
  var meanEVI = eviCollection.filterDate(startDate, endDate)
    .mean()
    .updateMask(studyRaster);
    Map.addLayer(meanEVI, {min: -1, max: 1, palette: ['white', 'green']},
    'Mean EVI ' + year + '-' + month, false);
};

years.getInfo().forEach(function(year) {
  for (var month = 6; month <= 7; month++) {
    calculateMonthlyCompositeEVI(year, month);
  }
});

