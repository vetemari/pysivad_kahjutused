// ============================================================
// Püsivalt madala EVI tuvastamine
// ============================================================

var lowEVIWithThreshold = function(image, eviThreshold) {
  return image.gte(-1).and(image.lte(eviThreshold));
};

var detectPersistentLowEVI = function(eviCollection, eviThreshold, timeThreshold) {
  var lowEVIMask = eviCollection.map(function(image) {
    return lowEVIWithThreshold(image, eviThreshold);
  });
  var lowEVIPercentage = lowEVIMask.sum().divide(eviCollection.size()).multiply(100);
  return lowEVIPercentage.gte(timeThreshold);
};

var eviThresholds = [0.30, 0.33, 0.35];
var timeThresholds = [55, 60, 65, 70, 75];

var allResults = [];

eviThresholds.forEach(function(eviThresh) {
  timeThresholds.forEach(function(timeThresh) {
    var result = detectPersistentLowEVI(eviCollection, eviThresh, timeThresh)
      .updateMask(studyRaster);
    allResults.push(result);
    var layerName = 'evi' + (eviThresh * 100).toFixed(0) + '_time' + timeThresh;
    Map.addLayer(result, {min: 0, max: 1, palette: ['green', 'red']}, layerName, false);
  });
});

