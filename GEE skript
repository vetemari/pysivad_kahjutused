var exportRegion = ee.Geometry.Rectangle([21.5, 57.5, 28.1, 59.9]);

var vectorToRaster = function(fc) {
  return fc
    .map(function(f) { return f.set('agri', 1); })
    .reduceToImage(['agri'], ee.Reducer.first())
    .reproject({crs: proj3301, scale: 10})
    .rename('agri')
    .unmask(0, false);
};

var r2017 = vectorToRaster(agriVec2017);
var r2018 = vectorToRaster(agriVec2018);
var r2019 = vectorToRaster(agriVec2019);
var r2020 = vectorToRaster(agriVec2020);
var r2021 = vectorToRaster(agriVec2021);
var r2022 = vectorToRaster(agriVec2022);
var r2023 = vectorToRaster(agriVec2023);
var r2024 = vectorToRaster(agriVec2024);

var agriYearCount = r2017.add(r2018).add(r2019).add(r2020)
                        .add(r2021).add(r2022).add(r2023)
                        .add(r2024);

var studyRaster = agriYearCount.gte(7).reproject({crs: proj3301, scale: 10});

Map.setCenter(25.0, 58.7, 7);

Map.addLayer(
  agriYearCount.updateMask(agriYearCount.gt(0)),
