var agriVec2018 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2018");
var agriVec2019 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2019");
var agriVec2020 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2020");
var agriVec2021 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2021");
var agriVec2022 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2022");
var agriVec2023 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2023");
var agriVec2024 = ee.FeatureCollection("projects/magister-458413/assets/neg10_pollud2024");

